// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  HR
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique

  @@map("departments")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  name         String
  phone        String?
  designation  String?
  salary       Float?
  joiningDate  DateTime    @default(now())
  status       Status      @default(ACTIVE)
  role         Role        @default(EMPLOYEE)
  profileImage String?
  isDeleted    Boolean     @default(false)
  
  // relation to department table
  departmentId String?    @relation(fields: [departmentId], references: [id])
  
  // for org hierarchy
  managerId    String?    @relation("EmployeeManager", fields: [managerId], references: [id])

  @@map("users")
  // ensures the PostgresSQL table is created as user instead of 'model User'
}